<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>일정관리 시스템</title>
  <!-- React 및 필수 라이브러리 로드 -->
  <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @keyframes pulse-orange {
      0% { background-color: #fb923c; box-shadow: 0 0 0 0 rgba(251, 146, 60, 0.7); }
      70% { background-color: #f97316; box-shadow: 0 0 0 10px rgba(251, 146, 60, 0); }
      100% { background-color: #fb923c; box-shadow: 0 0 0 0 rgba(251, 146, 60, 0); }
    }
    .btn-sync-dirty { animation: pulse-orange 2s infinite; color: white !important; }
    .donut-chart { transform: rotate(-90deg); }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .calendar-grid-cell { min-height: 80px; }
    @media (min-width: 768px) { .calendar-grid-cell { min-height: 120px; } }
    .schedule-item-monthly { transition: all 0.2s ease; }
    .schedule-item-monthly:hover { filter: brightness(0.9); transform: translateY(-1px); z-index: 10; }
    .shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
    @keyframes shake {
      10%, 90% { transform: translate3d(-1px, 0, 0); }
      20%, 80% { transform: translate3d(2px, 0, 0); }
      30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
      40%, 60% { transform: translate3d(4px, 0, 0); }
    }
    .toast-up { animation: toastUp 0.4s ease-out forwards; }
    @keyframes toastUp { from { transform: translateY(100px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  </style>
</head>
<body class="bg-slate-50 text-slate-900 overflow-hidden">
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useMemo, useCallback, useRef } = React;

    // --- 유틸리티 함수 ---
    const formatDate = (date) => {
      const d = new Date(date);
      if (isNaN(d.getTime())) return "";
      let month = '' + (d.getMonth() + 1);
      let day = '' + d.getDate();
      let year = d.getFullYear();
      if (month.length < 2) month = '0' + month;
      if (day.length < 2) day = '0' + day;
      return [year, month, day].join('-');
    };

    const formatTimeOnly = (timeVal) => {
      if (!timeVal) return "";
      if (typeof timeVal === 'string') {
        const match = timeVal.match(/(\d{2}:\d{2})/);
        return match ? match[0] : timeVal;
      }
      const d = new Date(timeVal);
      if (!isNaN(d.getTime())) return d.toTimeString().slice(0, 5);
      return timeVal;
    };

    const getDaysInMonth = (year, month) => new Date(year, month + 1, 0).getDate();
    const getFirstDayOfMonth = (year, month) => new Date(year, month, 1).getDay();
    const getImpScore = (imp) => {
      if (imp === '!!!') return 3;
      if (imp === '!!') return 2;
      if (imp === '!') return 1;
      return 0;
    };

    const parseDateStr = (dateStr) => {
      if (!dateStr) return null;
      const parts = dateStr.split('-');
      if (parts.length !== 3) return new Date(dateStr);
      return new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
    };

    const hasSchedulesInWeek = (dateStr, items) => {
      const targetDate = parseDateStr(dateStr);
      if (!targetDate) return false;
      const dayOfWeek = targetDate.getDay();
      
      const diffToMonday = targetDate.getDate() - dayOfWeek + (dayOfWeek === 0 ? -6 : 1);
      const monday = new Date(targetDate);
      monday.setDate(diffToMonday);
      monday.setHours(0, 0, 0, 0);
      
      const sunday = new Date(monday);
      sunday.setDate(monday.getDate() + 6);
      sunday.setHours(23, 59, 59, 999);
      
      return items.some(it => {
        if (it.type !== 'Schedule' || it.status === 'DELETED') return false;
        const itemDate = parseDateStr(it.date);
        if (!itemDate) return false;
        itemDate.setHours(0, 0, 0, 0);
        
        const itemEndDate = it.endDate ? parseDateStr(it.endDate) : itemDate;
        if (itemEndDate) itemEndDate.setHours(23, 59, 59, 999);
        
        return (itemDate <= sunday && itemEndDate >= monday);
      });
    };

    const getCategoryColor = (cat) => {
      switch (cat) {
        case 'Work': return 'bg-blue-100 text-blue-800 border border-blue-200';
        case 'Personal': return 'bg-emerald-100 text-emerald-800 border border-emerald-200';
        case 'Exercise': return 'bg-orange-100 text-orange-800 border border-orange-200';
        default: return 'bg-slate-700 text-white border border-slate-600';
      }
    };
    
    const getCategoryBadge = (cat) => {
      switch (cat) {
        case 'Work': return 'bg-blue-500';
        case 'Personal': return 'bg-emerald-500';
        case 'Exercise': return 'bg-orange-500';
        default: return 'bg-slate-400';
      }
    };

    // --- 개별 뷰 컴포넌트 ---
    const MonthlyView = ({ items, currentDate, setCurrentDate, setView, openEditor, todayStr, setViewingDate }) => {
      const year = currentDate.getFullYear();
      const month = currentDate.getMonth();
      const days = [];
      const startDay = getFirstDayOfMonth(year, month);
      const totalDaysCount = getDaysInMonth(year, month);
      for (let i = 0; i < startDay; i++) days.push(null);
      for (let i = 1; i <= totalDaysCount; i++) days.push(i);
      const daysOfWeek = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];

      const getEventDuration = (s) => {
        if (!s.endDate || s.endDate <= s.date) return 1;
        const d1 = new Date(s.date);
        const d2 = new Date(s.endDate);
        return Math.round((d2 - d1) / (1000 * 60 * 60 * 24)) + 1;
      };

      const sortSchedules = (a, b) => {
        const durA = getEventDuration(a);
        const durB = getEventDuration(b);
        if (durA !== durB) return durB - durA; // longer duration first
        const impA = getImpScore(a.importance);
        const impB = getImpScore(b.importance);
        if (impA !== impB) return impB - impA; // higher importance first
        if (a.date !== b.date) return a.date.localeCompare(b.date); // earlier start date first
        return a.id.localeCompare(b.id); // stable id sort
      };

      return (
        <div className="flex-1 p-2 md:p-4 overflow-auto">
          <div className="flex items-center justify-between mb-4 md:mb-6 px-1">
            <h2 className="text-lg md:text-2xl font-bold">{year}년 {month + 1}월</h2>
            <div className="flex gap-1">
              <button onClick={() => setCurrentDate(new Date(year, month - 1, 1))} className="p-2 bg-white border rounded hover:bg-gray-50"><i className="fas fa-chevron-left"></i></button>
              <button onClick={() => setCurrentDate(new Date())} className="px-3 py-2 bg-white border rounded font-bold text-xs shadow-sm hover:bg-gray-50">Today</button>
              <button onClick={() => setCurrentDate(new Date(year, month + 1, 1))} className="p-2 bg-white border rounded shadow-sm hover:bg-gray-50"><i className="fas fa-chevron-right"></i></button>
            </div>
          </div>
          <div className="grid grid-cols-7 border-t border-l border-slate-200 shadow-sm rounded-lg overflow-hidden text-[10px] md:text-xs">
            {daysOfWeek.map((day, i) => (
              <div key={day} className={`p-2 text-center font-bold border-r border-b ${i === 0 ? 'bg-red-50 text-red-500' : i === 6 ? 'bg-blue-50 text-blue-500' : 'bg-slate-50 text-slate-400'}`}>{day}</div>
            ))}
            {days.map((day, idx) => {
              const dateStr = day ? `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}` : null;
              const isToday = dateStr === todayStr;
              
              const daySchedules = items.filter(it => {
                if (it.type !== 'Schedule') return false;
                const isMulti = it.endDate && it.endDate !== "" && it.endDate !== it.date && it.endDate > it.date;
                if (!isMulti) {
                  return it.date === dateStr;
                }
                return dateStr >= it.date && dateStr <= it.endDate;
              }).sort(sortSchedules);

              const hasSchedules = daySchedules.length > 0;

              return (
                <div 
                  key={idx} 
                  className={`calendar-grid-cell p-1 border-r border-b transition-colors ${day && hasSchedules ? 'cursor-pointer' : ''} ${isToday ? 'bg-blue-50/50' : 'bg-white'}`}
                  onClick={() => {
                    if (day && hasSchedules) {
                      setViewingDate(dateStr);
                    }
                  }}
                  onDoubleClick={(e) => {
                    if (!day) return;
                    e.stopPropagation();
                    if (!hasSchedules && !hasSchedulesInWeek(dateStr, items)) {
                      setCurrentDate(parseDateStr(dateStr));
                      setView('weekly');
                    }
                  }}
                >
                  {day && <div className="flex flex-col h-full overflow-hidden">
                    <span className={`text-[10px] md:text-xs font-black px-1.5 py-0.5 rounded w-fit ${isToday ? 'bg-blue-600 text-white shadow-sm' : idx % 7 === 0 ? 'text-red-500' : idx % 7 === 6 ? 'text-blue-500' : 'text-slate-700'}`}>{day}</span>
                    <div className="flex flex-col gap-1 mt-1 overflow-y-auto no-scrollbar">
                      {daySchedules.map(s => {
                        const isMulti = s.endDate && s.endDate !== "" && s.endDate !== s.date && s.endDate > s.date;
                        const isStart = !isMulti || dateStr === s.date;
                        const isEnd = !isMulti || dateStr === s.endDate;
                        const showTitle = isStart || (idx % 7 === 0);

                        return (
                          <div 
                            key={s.id} 
                            onClick={(e) => { 
                              e.stopPropagation(); 
                              setViewingDate(dateStr); 
                            }} 
                            className={`schedule-item-monthly text-[8px] md:text-[10px] py-0.5 px-1.5 leading-tight whitespace-nowrap overflow-hidden text-ellipsis font-medium shadow-sm cursor-pointer ${getCategoryColor(s.category)}`}
                            style={{
                              marginLeft: isStart ? '0' : '-5px',
                              marginRight: isEnd ? '0' : '-5px',
                              borderTopLeftRadius: isStart ? '0.25rem' : '0',
                              borderBottomLeftRadius: isStart ? '0.25rem' : '0',
                              borderTopRightRadius: isEnd ? '0.25rem' : '0',
                              borderBottomRightRadius: isEnd ? '0.25rem' : '0',
                              borderLeftWidth: isStart ? '1px' : '0',
                              borderRightWidth: isEnd ? '1px' : '0',
                              zIndex: isMulti ? 5 : 1,
                            }}
                          >
                            {showTitle ? (
                              <>
                                {s.importance !== 'None' && <span className="mr-1 text-red-500 font-bold">{s.importance}</span>}
                                {s.recurrence && s.recurrence !== 'none' && <i className="fas fa-redo text-[8px] mr-1 opacity-60"></i>}
                                {s.title}
                              </>
                            ) : (
                              <span className="opacity-0">&nbsp;</span>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  </div>}
                </div>
              );
            })}
          </div>
        </div>
      );
    };

    const WeeklyView = ({ items, currentDate, setCurrentDate, toggleHabitStatus, openEditor, todayStr }) => {
      const curr = new Date(currentDate);
      const monday = new Date(curr.setDate(curr.getDate() - curr.getDay() + (curr.getDay() === 0 ? -6 : 1)));
      const weekDays = Array.from({length: 7}, (_, i) => new Date(new Date(monday).setDate(monday.getDate() + i)));
      const dayNames = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];

      return (
        <div className="flex-1 p-3 md:p-6 overflow-auto" id="weekly-scroll-container">
           <div className="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
            <h2 className="text-xl md:text-2xl font-bold">{monday.getFullYear()}년 {monday.getMonth() + 1}월 주간 일정</h2>
            <div className="flex gap-2">
              <button onClick={() => setCurrentDate(new Date(currentDate.setDate(currentDate.getDate()-7)))} className="p-2 bg-white border rounded shadow-sm hover:bg-gray-50 flex-1 md:flex-none"><i className="fas fa-chevron-left"></i></button>
              <button onClick={() => setCurrentDate(new Date())} className="px-4 py-2 bg-white border rounded font-bold text-sm shadow-sm hover:bg-gray-50 flex-1 md:flex-none">Today</button>
              <button onClick={() => setCurrentDate(new Date(currentDate.setDate(currentDate.getDate()+7)))} className="p-2 bg-white border rounded shadow-sm hover:bg-gray-50 flex-1 md:flex-none"><i className="fas fa-chevron-right"></i></button>
            </div>
          </div>
          <div className="space-y-4">
            {weekDays.map((d) => {
              const dateStr = formatDate(d);
              const dayItems = [];
              items.forEach(it => {
                const isMulti = it.endDate && it.endDate !== "" && it.endDate !== it.date && it.endDate > it.date;
                if (!isMulti) {
                  if (it.date === dateStr) {
                    dayItems.push(it);
                  }
                } else {
                  if (it.date === dateStr) {
                    dayItems.push({
                      ...it,
                      title: `${it.title} 시작일`
                    });
                  } else if (it.endDate === dateStr) {
                    dayItems.push({
                      ...it,
                      title: `${it.title} 종료일`
                    });
                  }
                }
              });
              dayItems.sort((a, b) => getImpScore(b.importance) - getImpScore(a.importance));
              const dayIdx = d.getDay();
              const isDayToday = dateStr === todayStr;
              return (
                <div key={dateStr} className="flex flex-col md:flex-row gap-2 md:gap-4">
                  <div className={`w-full md:w-32 p-3 rounded-xl border-2 flex md:flex-col items-center justify-between md:justify-center bg-white shadow-sm transition-all ${isDayToday ? 'border-blue-500 bg-blue-50' : dayIdx === 0 ? 'border-red-100 text-red-500' : dayIdx === 6 ? 'border-blue-100 text-blue-500' : 'border-slate-100'}`}>
                    <div className={`text-[10px] font-black uppercase ${isDayToday ? 'text-blue-600' : 'text-slate-400'}`}>{dayNames[dayIdx]}</div>
                    <div className={`text-2xl md:text-4xl font-black ${isDayToday ? 'text-blue-700' : 'text-slate-800'}`}>{d.getDate()}</div>
                  </div>
                  <div className="flex-1 bg-white p-3 rounded-xl border border-slate-200 shadow-sm flex flex-col gap-2">
                    {dayItems.length === 0 ? <div className="text-slate-300 italic text-xs py-4 text-center">No plans recorded.</div> : 
                      dayItems.map(it => (
                        <div key={it.id} className="flex items-center gap-3 p-2.5 rounded-xl hover:bg-slate-50 cursor-pointer shadow-sm border border-transparent hover:border-slate-100" onClick={() => openEditor(it)}>
                          <div className={`w-1.5 h-10 rounded-full ${getCategoryBadge(it.category)} shrink-0`}></div>
                          <div className="flex items-center gap-2">
                            {it.type === 'Habit' && (
                              <div 
                                className="w-7 h-7 flex items-center justify-center border-2 rounded-lg bg-white shadow-inner transition-all hover:scale-105 active:scale-95 shrink-0" 
                                onClick={(e) => { e.preventDefault(); e.stopPropagation(); toggleHabitStatus(it.id, it.isVirtual ? it.date : null, it.originalId); }}
                              >
                                {it.status === 'CHECK' && <i className="fas fa-check text-green-500"></i>}
                                {it.status === 'X' && <i className="fas fa-times text-red-400"></i>}
                              </div>
                            )}
                            {it.importance !== 'None' && <span className="text-red-600 font-black text-xl">{it.importance}</span>}
                          </div>
                          <div className="flex flex-col flex-1 min-w-0">
                            <span className="font-bold text-slate-800 text-base truncate">
                              {it.recurrence && it.recurrence !== 'none' && <i className="fas fa-redo text-[10px] text-slate-400 mr-2"></i>}
                              {it.title}
                            </span>
                            <div className="flex flex-wrap gap-3 items-center mt-0.5">
                              {it.time && <span className="text-[11px] text-slate-400 font-medium"><i className="far fa-clock mr-1"></i>{formatTimeOnly(it.time)}</span>}
                              {it.location && <span className="text-[11px] text-blue-400 font-bold truncate max-w-[150px]"><i className="fas fa-map-marker-alt mr-1"></i>{it.location}</span>}
                              {it.category && it.category !== 'None' && <span className={`text-[9px] px-1.5 py-0.5 rounded font-bold uppercase ${getCategoryColor(it.category)}`}>{it.category}</span>}
                            </div>
                          </div>
                          <i className="fas fa-chevron-right text-slate-200 text-xs"></i>
                        </div>
                      ))
                    }
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      );
    };

    const AchievementView = ({ items, currentDate }) => {
      const [targetMonth, setTargetMonth] = useState(`${currentDate.getFullYear()}-${String(currentDate.getMonth()+1).padStart(2, '0')}`);
      const filteredHabits = items.filter(it => it.type === 'Habit' && it.date && it.date.startsWith(targetMonth));
      const total = filteredHabits.length;
      const uncompleted = filteredHabits.filter(it => it.status === 'X').length;
      const completed = filteredHabits.filter(it => it.status === 'CHECK').length;
      const percentage = total === 0 ? 0 : Math.round((completed / total) * 100);
      const circumference = 2 * Math.PI * 95;
      const offset = circumference - (percentage / 100) * circumference;

      const failedHabits = filteredHabits.filter(it => it.status === 'X').sort((a, b) => b.date.localeCompare(a.date));

      return (
        <div className="flex-1 p-4 md:p-8 overflow-y-auto no-scrollbar">
          <div className="flex flex-col items-center max-w-4xl mx-auto bg-white p-6 md:p-12 rounded-3xl shadow-lg border">
            <div className="mb-8 w-full flex flex-col md:flex-row justify-between items-center gap-4">
              <h2 className="text-lg md:text-2xl font-black text-slate-800 tracking-tight uppercase">Habit Achievement</h2>
              <input type="month" value={targetMonth} onChange={(e) => setTargetMonth(e.target.value)} className="w-full md:w-auto p-2 border rounded-xl font-bold bg-slate-50 focus:ring-2 focus:ring-blue-500 outline-none" />
            </div>
            <div className="flex flex-col md:flex-row items-center gap-12 w-full justify-center">
              <div className="relative flex items-center justify-center p-4">
                <svg width="240" height="240" viewBox="0 0 240 240" className="donut-chart md:w-[320px] md:h-[320px]">
                  <circle cx="120" cy="120" r={95} fill="transparent" stroke="#fee2e2" strokeWidth="24" />
                  <circle cx="120" cy="120" r={95} fill="transparent" stroke="#22c55e" strokeWidth="24" strokeDasharray={circumference} strokeDashoffset={offset} strokeLinecap="round" style={{ transition: 'stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1)' }} />
                </svg>
                <div className="absolute inset-0 flex flex-col items-center justify-center">
                  <span className="text-4xl md:text-6xl font-black text-slate-800 leading-none">{percentage}%</span>
                  <span className="text-[10px] text-slate-400 font-bold uppercase mt-2 tracking-widest">Done</span>
                </div>
              </div>
              <div className="w-full md:flex-1 bg-slate-50 p-8 rounded-2xl border text-center shadow-inner">
                <div className="text-slate-400 text-xs font-black uppercase mb-4 tracking-widest">Stats Summary</div>
                <div className="text-5xl md:text-7xl font-black text-slate-800 mb-2 tracking-tighter">{completed} <span className="text-slate-300 text-3xl mx-2">/</span> {total}</div>
                <div className="mt-6 text-xs text-slate-500 bg-white px-6 py-3 rounded-full shadow-sm font-bold border border-slate-100">{total - completed - uncompleted} habits left this month</div>
              </div>
            </div>

            {/* 미달성 습관 (STATUS = 'X') 목록 */}
            <div className="w-full mt-12 border-t pt-8">
              <h3 className="text-base md:text-lg font-black text-slate-800 mb-4 flex items-center gap-2">
                <i className="fas fa-times-circle text-red-500"></i> 미달성 습관 목록 (Failed Habits)
              </h3>
              {failedHabits.length === 0 ? (
                <div className="text-slate-400 italic text-center py-8 bg-slate-50 rounded-2xl border border-dashed text-sm font-medium">
                  이번 달에 미달성한 습관이 없습니다! 아주 훌륭합니다! 🎉
                </div>
              ) : (
                <div className="overflow-x-auto rounded-2xl border border-slate-100 shadow-sm">
                  <table className="w-full text-left text-xs md:text-sm border-collapse bg-white">
                    <thead>
                      <tr className="bg-slate-50 text-slate-400 text-[10px] font-black uppercase tracking-wider border-b">
                        <th className="py-4 px-6 w-1/4">날짜 (Date)</th>
                        <th className="py-4 px-6 w-1/2">습관 내용 (Habit)</th>
                        <th className="py-4 px-6 w-1/4 text-right">카테고리 (Category)</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100">
                      {failedHabits.map((h) => (
                        <tr key={h.id} className="hover:bg-slate-50/50 transition-colors">
                          <td className="py-4 px-6 font-bold text-slate-500 font-mono">{h.date}</td>
                          <td className="py-4 px-6 font-black text-slate-800">
                            <div className="flex items-center gap-2">
                              <span className="w-2 h-2 rounded-full bg-red-400 shrink-0"></span>
                              <span>{h.title}</span>
                            </div>
                          </td>
                          <td className="py-4 px-6 text-right">
                            {h.category && h.category !== 'None' ? (
                              <span className={`text-[10px] px-2.5 py-1 rounded-full font-bold uppercase ${getCategoryColor(h.category)}`}>
                                {h.category}
                              </span>
                            ) : (
                              <span className="text-slate-300 font-medium">-</span>
                            )}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          </div>
        </div>
      );
    };

    // --- 메인 App 컴포넌트 ---
    const App = () => {
      const [view, setView] = useState('monthly');
      const [items, setItems] = useState([]);
      const [currentDate, setCurrentDate] = useState(new Date());
      const [isSidebarOpen, setIsSidebarOpen] = useState(window.innerWidth >= 768);
      const [isEditorOpen, setIsEditorOpen] = useState(false);
      const [isSettingsOpen, setIsSettingsOpen] = useState(false);
      const [isLoading, setIsLoading] = useState(true);
      const [isSyncing, setIsSyncing] = useState(false);
      const [editingItem, setEditingItem] = useState(null);
      const [viewingDate, setViewingDate] = useState(null);
      
      const [errorMsg, setErrorMsg] = useState("");
      const [toastData, setToastData] = useState(null);
      const [isDeleteConfirmOpen, setIsDeleteConfirmOpen] = useState(false);
      const syncTimeoutRef = useRef(null);

      const [settings, setSettings] = useState({ botToken: '', chatId: '', notificationHour: '08' });

      const todayStr = useMemo(() => formatDate(new Date()), []);

      const defaultForm = {
        title: '', date: formatDate(new Date()), endDate: formatDate(new Date()), time: '', location: '', description: '', type: 'Schedule', importance: 'None', status: '', category: 'None', recurrence: 'none'
      };
      const [formData, setFormData] = useState(defaultForm);

      useEffect(() => {
        if (typeof google !== 'undefined') {
          google.script.run.withSuccessHandler(res => {
            let success = false;
            let data = [];
            let errorMsg = "알 수 없는 오류";

            if (res) {
              if (Array.isArray(res)) {
                success = true;
                data = res;
              } else if (typeof res === 'object') {
                if (res.hasOwnProperty('success')) {
                  success = res.success;
                  data = Array.isArray(res.data) ? res.data : [];
                  errorMsg = res.message || errorMsg;
                } else {
                  success = true;
                  data = [res];
                }
              }
            }

            if (success) {
              setItems(data.map(it => ({ 
                ...it, 
                date: formatDate(it.date),
                endDate: it.endDate ? formatDate(it.endDate) : formatDate(it.date),
                time: formatTimeOnly(it.time) 
              })));
            } else {
              showToast("데이터 로드 실패: " + errorMsg, true);
            }
            setIsLoading(false);
          }).withFailureHandler(err => {
            showToast("통신 에러: " + err.message, true);
            setIsLoading(false);
          }).loadData();
          
          google.script.run.withSuccessHandler(res => {
            if (res) {
              if (res.success && res.data) {
                setSettings(res.data);
              } else if (res.botToken && res.chatId && res.notificationHour) {
                setSettings(res);
              }
            }
          }).getSettings();
        } else {
          // 로컬 데모 모드: localStorage에서 데이터 로드
          const localData = localStorage.getItem('planner_items');
          if (localData) {
            try {
              setItems(JSON.parse(localData));
            } catch (e) {
              console.error(e);
            }
          } else {
            // 데모용 샘플 데이터 추가
            const sampleData = [
              {
                id: "demo1",
                title: "프로젝트 기획 회의",
                date: formatDate(new Date()),
                endDate: formatDate(new Date(Date.now() + 2 * 24 * 60 * 60 * 1000)), // 3일 일정
                time: "10:00",
                location: "회의실 A",
                description: "신규 기능 기획 및 일정 조율",
                type: "Schedule",
                importance: "!!",
                status: "",
                category: "Work"
              },
              {
                id: "demo2",
                title: "피트니스 운동",
                date: formatDate(new Date()),
                endDate: formatDate(new Date()),
                time: "19:00",
                location: "헬스장",
                description: "유산소 및 근력 운동",
                type: "Schedule",
                importance: "None",
                status: "",
                category: "Exercise"
              }
            ];
            setItems(sampleData);
            localStorage.setItem('planner_items', JSON.stringify(sampleData));
          }
          const localSettings = localStorage.getItem('planner_settings');
          if (localSettings) {
            try { setSettings(JSON.parse(localSettings)); } catch(e){}
          }
          setIsLoading(false);
        }
      }, []);

      const showToast = (msg, isError = false) => {
        setToastData({ msg, isError });
        setTimeout(() => setToastData(null), 3000);
      };

      // 백그라운드 동기화 (Optimistic UI)
      const triggerSync = (newItems) => {
        if (syncTimeoutRef.current) clearTimeout(syncTimeoutRef.current);
        
        // 가상 아이템은 클라우드에 저장하지 않도록 필터링
        const physicalItems = newItems.filter(it => !it.isVirtual);
        
        syncTimeoutRef.current = setTimeout(() => {
          setIsSyncing(true);
          if (typeof google !== 'undefined') {
            google.script.run.withSuccessHandler((res) => {
              setIsSyncing(false);
              const isSuccess = res === "Success" || (res && res.success);
              if (!isSuccess) {
                showToast("동기화 실패: " + (res && res.message ? res.message : "알 수 없는 오류"), true);
              }
            }).withFailureHandler(err => {
              setIsSyncing(false);
              showToast("서버 오류: " + err.message, true);
            }).saveData(physicalItems);
          } else {
            localStorage.setItem('planner_items', JSON.stringify(physicalItems));
            setTimeout(() => { setIsSyncing(false); showToast("로컬 브라우저에 저장됨"); }, 800);
          }
        }, 1000);
      };

      const updateAndSync = (newItems) => {
        setItems(newItems);
        triggerSync(newItems);
      };

      // 가상 일정(반복 일정) 확장 로직
      const displayItems = useMemo(() => {
        const result = [];
        const today = new Date(currentDate.getFullYear(), currentDate.getMonth(), 1);
        const startRange = new Date(today.getFullYear(), today.getMonth() - 2, 1);
        const endRange = new Date(today.getFullYear(), today.getMonth() + 2, 0);

        items.forEach(it => {
          if (it.isVirtual) return; // 기존 물리 항목만 처리
          
          result.push(it);

          if (it.recurrence && it.recurrence !== 'none') {
            let current = new Date(it.date);
            while (true) {
              if (it.recurrence === 'daily') current.setDate(current.getDate() + 1);
              else if (it.recurrence === 'weekly') current.setDate(current.getDate() + 7);
              else if (it.recurrence === 'monthly') current.setMonth(current.getMonth() + 1);

              if (current > endRange) break;

              if (current >= startRange) {
                const dateStr = formatDate(current);
                const virtualId = `${it.id}_${dateStr}`;
                // 물리적 예외 처리 항목이 이미 존재하는지 확인
                const exceptionExists = items.some(ex => ex.id === virtualId || (ex.originalId === it.id && ex.date === dateStr));
                if (!exceptionExists) {
                  result.push({
                    ...it,
                    id: virtualId,
                    date: dateStr,
                    isVirtual: true,
                    originalId: it.id
                  });
                }
              }
            }
          }
        });
        return result;
      }, [items, currentDate]);

      const openEditor = (item = null) => {
        setErrorMsg(""); setIsDeleteConfirmOpen(false);
        if (item) { 
          setEditingItem(item); 
          setFormData({ ...item, endDate: item.endDate || item.date, time: formatTimeOnly(item.time) }); 
        } else { 
          setEditingItem(null); 
          setFormData(defaultForm); 
        }
        setIsEditorOpen(true);
      };

      const saveItem = () => {
        if (!formData.title || !formData.date) { setErrorMsg("Title과 Date는 필수 입력 항목입니다."); return; }
        const actualEndDate = formData.endDate || formData.date;
        if (actualEndDate < formData.date) { setErrorMsg("종료일은 시작일보다 빠를 수 없습니다."); return; }
        if (formData.time && !/^([01]\d|2[0-3]):([0-5]\d)$/.test(formData.time)) { setErrorMsg("시간 형식이 올바르지 않습니다 (HH:mm)."); return; }
        
        const finalFormData = { ...formData, endDate: actualEndDate };
        
        let newItems;
        if (editingItem) {
          if (editingItem.isVirtual) {
            // 가상 아이템을 수정할 경우 새로운 물리 항목 생성
            newItems = [...items, { ...finalFormData, id: editingItem.id, isVirtual: false }];
          } else {
            // 원본 수정
            newItems = items.map(it => it.id === editingItem.id ? { ...finalFormData, id: it.id, isVirtual: false } : it);
          }
        } else {
          newItems = [...items, { ...finalFormData, id: Date.now().toString(), isVirtual: false }];
        }
        
        updateAndSync(newItems);
        setIsEditorOpen(false);
      };

      const confirmDelete = () => {
        let newItems;
        if (editingItem.isVirtual) {
          // 가상 아이템 삭제(스킵) 시 예외를 생성해 status: 'DELETED'로 관리
          newItems = [...items, { ...editingItem, status: 'DELETED', isVirtual: false }];
        } else {
          // 원본 삭제
          newItems = items.filter(it => it.id !== editingItem.id);
        }
        updateAndSync(newItems);
        setIsEditorOpen(false); 
        setIsDeleteConfirmOpen(false);
      };

      const toggleHabitStatus = useCallback((id, virtualDate, originalId) => {
        setItems(prevItems => {
          let nextItems = [...prevItems];
          if (originalId && virtualDate) { 
            // 가상 항목을 토글하면 물리적 완료 항목 생성
            const originalItem = prevItems.find(it => it.id === originalId);
            if (originalItem) {
              nextItems.push({
                ...originalItem,
                id: id,
                date: virtualDate,
                status: 'CHECK',
                recurrence: 'none',
                isVirtual: false,
                originalId: originalId
              });
            }
          } else {
            // 물리 항목 토글
            nextItems = nextItems.map(it => {
              if (it.id === id) {
                let nextStatus = it.status === '' ? 'CHECK' : it.status === 'CHECK' ? 'X' : '';
                return { ...it, status: nextStatus };
              }
              return it;
            });
          }
          triggerSync(nextItems); // 백그라운드 동기화
          return nextItems;
        });
      }, []);

      const [isTestingTelegram, setIsTestingTelegram] = useState(false);

      const handleTestTelegram = () => {
        if (!settings.botToken || !settings.chatId) {
          showToast("Bot Token과 Chat ID를 입력해주세요.", true);
          return;
        }
        setIsTestingTelegram(true);
        if (typeof google !== 'undefined') {
          google.script.run.withSuccessHandler((res) => {
            setIsTestingTelegram(false);
            if (res.success) {
              showToast("텔레그램 메시지 전송 성공!");
            } else {
              showToast("전송 실패: " + res.message, true);
            }
          }).withFailureHandler(err => {
            setIsTestingTelegram(false);
            showToast("서버 오류: " + err.message, true);
          }).testTelegram(settings.botToken, settings.chatId);
        } else {
          setTimeout(() => {
            setIsTestingTelegram(false);
            showToast("텔레그램 전송 테스트 성공 (데모)");
          }, 1000);
        }
      };

      const handleSaveSettings = () => {
        setIsSyncing(true);
        if (typeof google !== 'undefined') {
          google.script.run.withSuccessHandler((res) => {
            setIsSyncing(false);
            if (res.success) {
              setIsSettingsOpen(false);
              showToast("설정이 저장되었습니다.");
            } else {
              showToast("설정 저장 실패: " + res.message, true);
            }
          }).withFailureHandler(err => {
            setIsSyncing(false);
            showToast("서버 오류: " + err.message, true);
          }).saveSettings(settings);
        } else {
           localStorage.setItem('planner_settings', JSON.stringify(settings));
           setTimeout(() => { setIsSyncing(false); setIsSettingsOpen(false); showToast("설정 적용 완료 (데모)"); }, 800);
        }
      };

      const changeView = (v) => { setView(v); if (window.innerWidth < 768) setIsSidebarOpen(false); };

      // DELETED 상태인 항목은 달력/주간 뷰에서 숨기기
      const visibleDisplayItems = useMemo(() => displayItems.filter(it => it.status !== 'DELETED'), [displayItems]);

      return (
        <div className="flex h-screen w-full overflow-hidden font-sans relative">
          
          {isLoading && items.length === 0 && (
            <div className="fixed inset-0 z-[200] bg-white flex flex-col items-center justify-center">
               <div className="w-16 h-16 border-4 border-blue-100 border-t-blue-600 rounded-full animate-spin mb-4"></div>
               <p className="font-bold text-slate-400 tracking-widest animate-pulse uppercase text-xs">Connecting to Cloud...</p>
            </div>
          )}

          {toastData && (
            <div className="fixed bottom-10 left-1/2 -translate-x-1/2 z-[300] toast-up">
              <div className={`px-8 py-4 rounded-2xl font-bold shadow-2xl flex items-center gap-3 border ${toastData.isError ? 'bg-red-600 text-white border-red-500' : 'bg-slate-900 text-white border-white/10'}`}>
                <i className={`fas ${toastData.isError ? 'fa-exclamation-circle' : 'fa-check-circle'} ${toastData.isError ? 'text-white' : 'text-green-400'}`}></i>
                {toastData.msg}
              </div>
            </div>
          )}

          <div className={`fixed md:static inset-0 z-50 transition-all duration-300 ease-in-out overflow-hidden ${isSidebarOpen ? 'translate-x-0 w-[80%] md:w-64' : '-translate-x-full md:translate-x-0 md:w-20'} bg-slate-900 text-white flex flex-col shrink-0`}>
            <div className="p-6 flex items-center justify-between border-b border-slate-800 h-20 shrink-0">
              <div className="flex items-center gap-4">
                <button onClick={() => setIsSidebarOpen(!isSidebarOpen)} className="text-white hover:text-blue-400 transition-colors">
                  <i className={`fas ${isSidebarOpen ? 'fa-times' : 'fa-bars'} text-xl`}></i>
                </button>
                {isSidebarOpen && <span className="font-black tracking-tighter text-2xl bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent">PLANNER</span>}
              </div>
            </div>
            <nav className="flex-1 px-4 py-8 space-y-3">
              <button onClick={() => changeView('monthly')} className={`w-full flex items-center gap-4 p-4 rounded-xl transition-all ${view === 'monthly' ? 'bg-blue-600 shadow-lg' : 'text-slate-400 hover:bg-slate-800'}`}>
                <i className="fas fa-calendar-alt w-6 text-center text-lg"></i>
                {isSidebarOpen && <span className="font-bold whitespace-nowrap">Monthly</span>}
              </button>
              <button onClick={() => changeView('weekly')} className={`w-full flex items-center gap-4 p-4 rounded-xl transition-all ${view === 'weekly' ? 'bg-blue-600 shadow-lg' : 'text-slate-400 hover:bg-slate-800'}`}>
                <i className="fas fa-calendar-week w-6 text-center text-lg"></i>
                {isSidebarOpen && <span className="font-bold whitespace-nowrap">Weekly</span>}
              </button>
              <button onClick={() => changeView('achievement')} className={`w-full flex items-center gap-4 p-4 rounded-xl transition-all ${view === 'achievement' ? 'bg-blue-600 shadow-lg' : 'text-slate-400 hover:bg-slate-800'}`}>
                <i className="fas fa-chart-pie w-6 text-center text-lg"></i>
                {isSidebarOpen && <span className="font-bold whitespace-nowrap">Achievement</span>}
              </button>
            </nav>
            <div className="p-4 border-t border-slate-800">
              <div className={`w-full flex items-center justify-center gap-3 p-4 rounded-xl text-sm font-black transition-all bg-slate-800 text-slate-500`}>
                <i className={`fas ${isSyncing ? 'fa-spinner fa-spin text-blue-400' : 'fa-cloud text-green-400'} text-lg`}></i>
                {isSidebarOpen && <span className="whitespace-nowrap">{isSyncing ? 'Syncing...' : 'Live Sync On'}</span>}
              </div>
            </div>
          </div>
          
          {isSidebarOpen && window.innerWidth < 768 && <div className="fixed inset-0 bg-black/60 backdrop-blur-sm z-40" onClick={() => setIsSidebarOpen(false)}></div>}

          <div className="flex-1 flex flex-col relative overflow-hidden bg-slate-50">
            <header className="h-20 bg-white border-b px-4 md:px-8 flex items-center justify-between shrink-0 shadow-sm z-10">
              <div className="flex items-center gap-4">
                {(!isSidebarOpen || window.innerWidth < 768) && (
                  <button onClick={() => setIsSidebarOpen(true)} className="w-10 h-10 bg-slate-900 text-white rounded-xl flex items-center justify-center shadow-lg transition-all active:scale-95">
                    <i className="fas fa-bars"></i>
                  </button>
                )}
                <h1 className="font-black text-xl uppercase text-slate-800 tracking-tight">{view} overview</h1>
              </div>
              <div className="flex items-center gap-3">
                <button onClick={() => setIsSettingsOpen(true)} className="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-100 text-slate-500 hover:bg-slate-200 transition-colors shadow-sm">
                  <i className="fas fa-cog text-xl"></i>
                </button>
                <button onClick={() => openEditor()} className="bg-blue-600 text-white px-5 py-2.5 rounded-xl text-sm font-black shadow-lg shadow-blue-200 transition-transform active:scale-95">
                  <i className="fas fa-plus mr-2"></i> NEW
                </button>
              </div>
            </header>

            <main className="flex-1 flex flex-col overflow-hidden">
              {view === 'monthly' && <MonthlyView items={visibleDisplayItems} currentDate={currentDate} setCurrentDate={setCurrentDate} setView={setView} openEditor={openEditor} todayStr={todayStr} setViewingDate={setViewingDate} />}
              {view === 'weekly' && <WeeklyView items={visibleDisplayItems} currentDate={currentDate} setCurrentDate={setCurrentDate} toggleHabitStatus={toggleHabitStatus} openEditor={openEditor} todayStr={todayStr} />}
              {view === 'achievement' && <AchievementView items={visibleDisplayItems} currentDate={currentDate} />}
            </main>

            {/* 환경설정 모달 */}
            {isSettingsOpen && (
              <div className="fixed inset-0 bg-slate-900/60 flex items-center justify-center z-[150] p-4 backdrop-blur-md">
                <div className="bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden flex flex-col border border-white/20">
                  <div className="p-8 border-b flex justify-between items-center bg-slate-50/50">
                    <h3 className="text-2xl font-black text-slate-800 tracking-tight flex items-center gap-2">
                      <i className="fab fa-telegram text-blue-500"></i> Telegram 알림 설정
                    </h3>
                    <button onClick={() => setIsSettingsOpen(false)} className="w-10 h-10 flex items-center justify-center rounded-full bg-slate-100 text-slate-400 hover:text-red-500 transition-all"><i className="fas fa-times"></i></button>
                  </div>
                  <div className="p-8 space-y-6 max-h-[60vh] overflow-y-auto no-scrollbar">
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase block mb-2 px-1">Telegram Bot Token</label>
                      <input type="text" className="w-full p-4 bg-slate-100 border-2 border-transparent rounded-2xl focus:bg-white focus:border-blue-500 outline-none font-bold text-slate-700 shadow-inner" placeholder="0000000000:AAxxx..." value={settings.botToken || ''} onChange={e => setSettings({...settings, botToken: e.target.value})} />
                      <p className="mt-1.5 text-[9px] text-slate-400 px-1 font-medium leading-relaxed">
                        * Telegram에서 <b>@BotFather</b>에게 <code>/newbot</code> 명령어로 봇을 생성하고 발급받은 HTTP API 토큰을 입력하세요.
                      </p>
                    </div>
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase block mb-2 px-1">Telegram Chat ID</label>
                      <input type="text" className="w-full p-4 bg-slate-100 border-2 border-transparent rounded-2xl focus:bg-white focus:border-blue-500 outline-none font-bold text-slate-700 shadow-inner" placeholder="123456789" value={settings.chatId || ''} onChange={e => setSettings({...settings, chatId: e.target.value})} />
                      <p className="mt-1.5 text-[9px] text-slate-400 px-1 font-medium leading-relaxed">
                        * <b>@userinfobot</b> 혹은 <b>@GetChatID_Bot</b>을 통해 나의 고유 숫자 ID를 확인해 입력하세요. <i>(주의: 생성한 봇에 먼저 대화 시작(Start)을 눌러야 알림을 받을 수 있습니다.)</i>
                      </p>
                    </div>
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase block mb-2 px-1">Notification Time (Daily)</label>
                      <select className="w-full p-4 bg-slate-100 border-2 border-transparent rounded-2xl focus:bg-white focus:border-blue-500 outline-none font-bold text-slate-700 appearance-none shadow-inner" value={settings.notificationHour} onChange={e => setSettings({...settings, notificationHour: e.target.value})}>
                        {Array.from({length: 24}).map((_, i) => (
                          <option key={i} value={String(i).padStart(2, '0')}>{String(i).padStart(2, '0')}:00</option>
                        ))}
                      </select>
                      <p className="mt-1.5 text-[10px] text-slate-400 px-1 font-medium">* 매일 지정된 시간에 오늘 일정을 텔레그램으로 전송합니다.</p>
                    </div>
                  </div>
                  <div className="p-8 border-t bg-slate-50/50 space-y-3 shrink-0">
                    <button onClick={handleTestTelegram} disabled={isTestingTelegram || isSyncing} className="w-full bg-slate-800 text-white p-4 rounded-2xl font-black text-xs transition-all active:scale-95 uppercase tracking-wider flex items-center justify-center gap-2 shadow-md hover:bg-slate-700">
                      {isTestingTelegram ? <i className="fas fa-spinner fa-spin"></i> : <i className="fab fa-telegram-plane"></i>}
                      테스트 메시지 전송
                    </button>
                    <button onClick={handleSaveSettings} disabled={isSyncing} className="w-full bg-blue-600 text-white p-4 rounded-2xl font-black text-sm shadow-xl shadow-blue-200 transition-all active:scale-95 uppercase tracking-widest">
                      {isSyncing ? <i className="fas fa-spinner fa-spin mr-2"></i> : 'Apply Settings'}
                    </button>
                  </div>
                </div>
              </div>
            )}

            {/* 에디터 모달 */}
            {isEditorOpen && (
              <div className="fixed inset-0 bg-slate-900/60 flex items-center justify-center z-[100] p-2 md:p-4 backdrop-blur-md">
                <div className="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden flex flex-col border border-white/20 relative">
                  {isDeleteConfirmOpen && (
                    <div className="absolute inset-0 bg-white/95 z-[120] flex flex-col items-center justify-center p-8 text-center animate-in fade-in zoom-in duration-200">
                      <div className="w-16 h-16 bg-red-100 text-red-500 rounded-full flex items-center justify-center text-2xl mb-4"><i className="fas fa-trash-alt"></i></div>
                      <h4 className="text-xl font-black text-slate-800 mb-2">{editingItem?.isVirtual ? '이 일정을 지우시겠습니까?' : '시리즈 전체를 삭제하시겠습니까?'}</h4>
                      <p className="text-slate-400 text-sm mb-8 leading-relaxed text-center px-4">이 작업은 되돌릴 수 없으며<br/>선택한 일정이 삭제됩니다.</p>
                      <div className="flex gap-3 w-full mt-4">
                        <button onClick={confirmDelete} className="flex-1 bg-red-500 text-white py-4 rounded-2xl font-black text-sm shadow-lg shadow-red-100 hover:bg-red-600 transition-colors">네, 삭제합니다</button>
                        <button onClick={() => setIsDeleteConfirmOpen(false)} className="flex-1 bg-slate-100 text-slate-600 py-4 rounded-2xl font-black text-sm hover:bg-slate-200 transition-colors">취소</button>
                      </div>
                    </div>
                  )}

                  <div className="p-6 md:p-8 border-b flex justify-between items-center bg-slate-50/50">
                    <div>
                      <h3 className="text-xl md:text-2xl font-black text-slate-800 tracking-tight">{editingItem ? 'Update Item' : 'Create Item'}</h3>
                      <p className="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1 italic">Planning Mode</p>
                    </div>
                    <button onClick={() => setIsEditorOpen(false)} className="w-10 h-10 flex items-center justify-center rounded-full bg-slate-100 text-slate-400 hover:bg-red-50 hover:text-red-500 transition-all"><i className="fas fa-times"></i></button>
                  </div>
                  
                  <div className="p-6 md:p-8 space-y-4 md:space-y-6 overflow-y-auto max-h-[65vh] no-scrollbar">
                    {errorMsg && <div className="p-4 bg-red-500 text-white rounded-2xl text-xs font-bold shake shadow-md flex items-center gap-2"><i className="fas fa-exclamation-circle"></i>{errorMsg}</div>}
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">Title *</label>
                      <input className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl focus:bg-white focus:border-blue-500 outline-none font-bold text-slate-700 text-sm md:text-base transition-all shadow-inner" placeholder="What's the plan?" value={formData.title} onChange={e => { setErrorMsg(""); setFormData({...formData, title: e.target.value}); }} />
                    </div>
                    <div className="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
                      <div>
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">시작일 *</label>
                        <input type="date" className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl outline-none font-bold text-slate-700 text-xs md:text-sm shadow-inner" value={formData.date} onChange={e => setFormData({...formData, date: e.target.value, endDate: formData.endDate && formData.endDate >= e.target.value ? formData.endDate : e.target.value})} disabled={editingItem && editingItem.isVirtual} />
                      </div>
                      <div>
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">종료일</label>
                        <input type="date" className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl outline-none font-bold text-slate-700 text-xs md:text-sm shadow-inner" value={formData.endDate || ""} onChange={e => setFormData({...formData, endDate: e.target.value})} disabled={editingItem && editingItem.isVirtual} />
                      </div>
                      <div>
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">Time (HH:mm)</label>
                        <input type="text" className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl outline-none font-bold text-slate-700 text-xs md:text-sm shadow-inner" placeholder="HH:mm" value={formData.time} onChange={e => setFormData({...formData, time: e.target.value})} />
                      </div>
                    </div>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                      <div>
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">Category</label>
                        <select className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl outline-none font-bold text-slate-700 text-sm shadow-inner" value={formData.category} onChange={(e) => setFormData({...formData, category: e.target.value})}>
                          <option value="None">None</option>
                          <option value="Work">Work</option>
                          <option value="Personal">Personal</option>
                          <option value="Exercise">Exercise</option>
                        </select>
                      </div>
                      <div>
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">Recurrence</label>
                        <select className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl outline-none font-bold text-slate-700 text-sm shadow-inner" value={formData.recurrence} onChange={(e) => setFormData({...formData, recurrence: e.target.value})} disabled={editingItem && editingItem.isVirtual}>
                          <option value="none">None</option>
                          <option value="daily">Daily</option>
                          <option value="weekly">Weekly</option>
                          <option value="monthly">Monthly</option>
                        </select>
                      </div>
                    </div>
                    <div className="grid grid-cols-2 gap-4 md:gap-6">
                      <div>
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">Type *</label>
                        <select className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl outline-none font-bold text-slate-700 text-sm shadow-inner" value={formData.type} onChange={(e) => setFormData({...formData, type: e.target.value})}>
                          <option value="Schedule">Schedule</option>
                          <option value="Habit">Habit</option>
                        </select>
                      </div>
                      <div>
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">Importance *</label>
                        <select className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl outline-none font-bold text-slate-700 text-sm shadow-inner" value={formData.importance} onChange={(e) => setFormData({...formData, importance: e.target.value})}>
                          <option value="None">None</option>
                          <option value="!">!</option>
                          <option value="!!">!!</option>
                          <option value="!!!">!!!</option>
                        </select>
                      </div>
                    </div>
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">Location</label>
                      <input className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl focus:bg-white focus:border-blue-500 outline-none font-bold text-slate-700 text-sm shadow-inner" placeholder="Where?" value={formData.location} onChange={(e) => setFormData({...formData, location: e.target.value})} />
                    </div>
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">Description</label>
                      <textarea className="w-full p-3 md:p-4 bg-slate-100 border-2 border-transparent rounded-xl md:rounded-2xl h-24 md:h-28 resize-none focus:bg-white focus:border-blue-500 outline-none font-medium text-slate-600 text-sm shadow-inner" placeholder="Details..." value={formData.description} onChange={(e) => setFormData({...formData, description: e.target.value})}></textarea>
                    </div>
                  </div>
                  <div className="p-6 md:p-8 border-t bg-slate-50/50 flex gap-4 shrink-0">
                    <button onClick={saveItem} className="flex-1 bg-blue-600 text-white p-4 md:p-5 rounded-2xl font-black text-sm shadow-xl shadow-blue-100 hover:bg-blue-700 transition-all active:scale-95">SAVE CHANGES</button>
                    {editingItem && (
                      <button onClick={() => setIsDeleteConfirmOpen(true)} className="px-6 md:px-8 bg-white text-red-500 border-2 border-red-50 rounded-2xl font-black text-sm hover:bg-red-50 transition-colors">DELETE</button>
                    )}
                  </div>
                </div>
              </div>
            )}

            {/* 일별 일정 목록 모달 */}
            {viewingDate && (
              <div className="fixed inset-0 bg-slate-900/60 flex items-center justify-center z-[140] p-4 backdrop-blur-md animate-in fade-in duration-200">
                <div className="bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden flex flex-col border border-white/20">
                  <div className="p-6 md:p-8 border-b flex justify-between items-center bg-slate-50/50">
                    <div>
                      <h3 className="text-xl md:text-2xl font-black text-slate-800 tracking-tight">{viewingDate} 일정</h3>
                      <p className="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Schedules List</p>
                    </div>
                    <button onClick={() => setViewingDate(null)} className="w-10 h-10 flex items-center justify-center rounded-full bg-slate-100 text-slate-400 hover:text-red-500 transition-all"><i className="fas fa-times"></i></button>
                  </div>
                  <div className="p-6 md:p-8 space-y-4 max-h-[50vh] overflow-y-auto no-scrollbar">
                    {items.filter(it => {
                      if (it.type !== 'Schedule' || it.status === 'DELETED') return false;
                      const isMulti = it.endDate && it.endDate !== "" && it.endDate !== it.date && it.endDate > it.date;
                      if (!isMulti) {
                        return it.date === viewingDate;
                      }
                      return viewingDate >= it.date && viewingDate <= it.endDate;
                    }).sort((a, b) => getImpScore(b.importance) - getImpScore(a.importance)).map(s => (
                      <div 
                        key={s.id} 
                        onClick={() => {
                          setViewingDate(null);
                          openEditor(s);
                        }}
                        className="flex items-center gap-3 p-3.5 rounded-2xl hover:bg-slate-50 cursor-pointer shadow-sm border border-slate-100 transition-all hover:scale-[1.01]"
                      >
                        <div className={`w-1.5 h-10 rounded-full ${getCategoryBadge(s.category)} shrink-0`}></div>
                        <div className="flex flex-col flex-1 min-w-0">
                          <span className="font-bold text-slate-800 text-sm md:text-base truncate">
                            {s.recurrence && s.recurrence !== 'none' && <i className="fas fa-redo text-[10px] text-slate-400 mr-2"></i>}
                            {s.title}
                          </span>
                          <div className="flex flex-wrap gap-2 items-center mt-1">
                            {s.time && <span className="text-[10px] text-slate-400 font-medium"><i className="far fa-clock mr-1"></i>{formatTimeOnly(s.time)}</span>}
                            {s.location && <span className="text-[10px] text-blue-400 font-bold truncate max-w-[120px]"><i className="fas fa-map-marker-alt mr-1"></i>{s.location}</span>}
                            {s.category && s.category !== 'None' && <span className={`text-[8px] px-1.5 py-0.5 rounded font-bold uppercase ${getCategoryColor(s.category)}`}>{s.category}</span>}
                            {s.importance !== 'None' && <span className="text-[10px] text-red-500 font-bold">{s.importance}</span>}
                          </div>
                          {s.description && (
                            <p className="text-[11px] text-slate-400 mt-1 truncate">{s.description}</p>
                          )}
                        </div>
                        <i className="fas fa-chevron-right text-slate-300 text-xs"></i>
                      </div>
                    ))}
                  </div>
                  <div className="p-6 md:p-8 border-t bg-slate-50/50 flex gap-4 shrink-0">
                    <button 
                      onClick={() => {
                        const defaultDate = viewingDate;
                        setViewingDate(null);
                        openEditor({
                          ...defaultForm,
                          date: defaultDate,
                          endDate: defaultDate
                        });
                      }} 
                      className="w-full bg-blue-600 text-white p-4 rounded-2xl font-black text-sm shadow-xl shadow-blue-100 hover:bg-blue-700 transition-all active:scale-95 text-center"
                    >
                      <i className="fas fa-plus mr-2"></i> 새 일정 추가
                    </button>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      );
    };

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
