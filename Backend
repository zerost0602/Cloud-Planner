/**
 * 웹 앱 진입점
 */
function doGet() {
  return HtmlService.createTemplateFromFile('index')
    .evaluate()
    .setTitle('일정관리 프로그램')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

/**
 * 시트 초기화 및 헤더 체크
 */
function getSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName('Schedules');
  const headers = ['id', 'title', 'date', 'time', 'location', 'description', 'type', 'importance', 'status', 'updatedAt'];
  
  if (!sheet) {
    sheet = ss.insertSheet('Schedules');
    sheet.appendRow(headers);
    sheet.setFrozenRows(1);
  }
  return sheet;
}

/**
 * 환경설정 시트 가져오기 (단일 행 유지 보장)
 */
function getSettingsSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName('Settings');
  if (!sheet) {
    sheet = ss.insertSheet('Settings');
    sheet.appendRow(['email', 'notificationHour', 'updatedAt']);
    sheet.setFrozenRows(1);
  }
  return sheet;
}

/**
 * 설정값 불러오기
 */
function getSettings() {
  const sheet = getSettingsSheet();
  const data = sheet.getDataRange().getValues();
  if (data.length <= 1) return { email: Session.getActiveUser().getEmail(), notificationHour: "08" };
  return {
    email: data[1][0],
    notificationHour: data[1][1]
  };
}

/**
 * 설정값 저장 (중복 저장 방지 및 트리거 재설정)
 */
function saveSettings(settings) {
  const sheet = getSettingsSheet();
  const headers = ['email', 'notificationHour', 'updatedAt'];
  
  sheet.clear(); 
  sheet.appendRow(headers);
  sheet.appendRow([settings.email, settings.notificationHour, new Date()]);
  sheet.setFrozenRows(1);
  
  manageTriggers(parseInt(settings.notificationHour));
  return "Success";
}

/**
 * 시간 기반 트리거 관리
 */
function manageTriggers(hour) {
  const triggers = ScriptApp.getProjectTriggers();
  triggers.forEach(t => {
    if (t.getHandlerFunction() === 'sendDailyNotification') {
      ScriptApp.deleteTrigger(t);
    }
  });
  
  // 매일 지정된 시간에 실행되는 트리거 생성
  ScriptApp.newTrigger('sendDailyNotification')
    .timeBased()
    .everyDays(1)
    .atHour(hour)
    .nearMinute(0) // 정각 근처 실행 시도
    .create();
}

/**
 * 매일 일정 메일 발송 로직 (Schedule과 Habit 모두 포함)
 */
function sendDailyNotification() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const tz = ss.getSpreadsheetTimeZone(); // 스프레드시트 시간대 사용
  const settings = getSettings();
  
  if (!settings.email) return;
  
  const todayStr = Utilities.formatDate(new Date(), tz, "yyyy-MM-dd");
  const items = loadData();
  
  // 오늘 날짜이고 Schedule 또는 Habit인 항목 필터링
  const todayItems = items.filter(it => it.date === todayStr && (it.type === 'Schedule' || it.type === 'Habit'));
  
  if (todayItems.length === 0) return; 
  
  const body = todayItems.map(s => {
    const typeLabel = s.type === 'Habit' ? '[습관]' : '[일정]';
    const timePart = s.time ? ` [${s.time}]` : "";
    const locPart = s.location ? ` @${s.location}` : "";
    const importance = s.importance && s.importance !== 'None' ? ` (${s.importance})` : "";
    return `- ${typeLabel}${importance} ${s.title}${timePart}${locPart}`;
  }).join('\n');
  
  const subject = `[PLANNER] ${todayStr} 오늘의 할 일 알림`;
  const message = `안녕하세요,\n\n오늘(${todayStr}) 예정된 리스트입니다:\n\n${body}\n\n오늘도 좋은 하루 되세요!`;
  
  GmailApp.sendEmail(settings.email, subject, message);
}

/**
 * 모든 일정 데이터 읽기
 */
function loadData() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const tz = ss.getSpreadsheetTimeZone();
    const sheet = getSheet();
    const values = sheet.getDataRange().getValues();
    if (values.length <= 1) return [];
    
    const headers = values.shift();
    return values.map(row => {
      let obj = {};
      headers.forEach((header, i) => {
        let val = row[i];
        if (val instanceof Date) {
          val = (header === 'date') 
            ? Utilities.formatDate(val, tz, "yyyy-MM-dd")
            : Utilities.formatDate(val, tz, "yyyy-MM-dd HH:mm:ss");
        }
        if (header === 'id') val = val.toString();
        obj[header] = val || "";
      });
      return obj;
    });
  } catch (e) {
    console.error("loadData error: " + e.message);
    return [];
  }
}

/**
 * 데이터 저장 (최적화 버전)
 * - 날짜 계산을 루프 밖으로 빼서 1회만 실행
 * - 헤더와 데이터를 합쳐서 단 1번의 setValues로 처리
 * - 시트를 완전히 비우고 다시 써서 정합성 유지 및 속도 향상
 */
function saveData(items) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const tz = ss.getSpreadsheetTimeZone();
  const sheet = getSheet();
  
  // 1. 저장 시점의 시간은 딱 한 번만 계산 (성능 향상 핵심)
  const nowStr = Utilities.formatDate(new Date(), tz, "yyyy-MM-dd HH:mm:ss");
  
  // 2. 헤더 정의
  const headers = ['id', 'title', 'date', 'time', 'location', 'description', 'type', 'importance', 'status', 'updatedAt'];
  
  // 3. 헤더를 포함한 전체 데이터를 2차원 배열 하나로 준비
  let dataToWrite = [headers];

  if (items && items.length > 0) {
    const bodyRows = items.map(item => [
      item.id || "", 
      item.title || "", 
      item.date || "", 
      item.time || "", 
      item.location || "", 
      item.description || "", 
      item.type || "Schedule", 
      item.importance || "None", 
      item.status || "", 
      nowStr // 미리 계산해둔 시간 값 사용
    ]);
    // 헤더 배열 뒤에 데이터 배열 연결
    dataToWrite = dataToWrite.concat(bodyRows);
  }
  
  // 4. 시트 전체 초기화 (데이터 꼬임 방지 및 속도 최적화)
  sheet.clear(); 
  
  // 5. 단 한 번의 통신으로 모든 데이터(헤더+본문) 쓰기
  sheet.getRange(1, 1, dataToWrite.length, headers.length).setValues(dataToWrite);
  
  // 6. 편의성을 위해 첫 행(헤더) 고정
  sheet.setFrozenRows(1);

/**
 * 선택한 월(targetMonth, 예: "2026-03")의 계정 목록, 실제 지출, 예산 내역을 한 번에 가져옵니다.
 */
function getExpenseData(targetMonth) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  
  // 1. Settings 시트에서 비용(Expenses) 계정과목 목록 가져오기
  const settingsSheet = ss.getSheetByName('Settings');
  let expenseAccounts = [];
  if (settingsSheet) {
    const data = settingsSheet.getDataRange().getValues();
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === 'accounts') {
        try {
          const accountsJson = JSON.parse(data[i][1]);
          if (accountsJson.expenses) {
            expenseAccounts = accountsJson.expenses.map(acc => acc.name);
          }
        } catch(e) { console.error("Settings JSON parsing error", e); }
        break;
      }
    }
  }

  // 2. Transactions 시트에서 해당 월의 실제 지출 데이터 필터링
  const txSheet = ss.getSheetByName('Transactions');
  let monthlyExpenses = [];
  if (txSheet) {
    const data = txSheet.getDataRange().getValues();
    const headers = data[0];
    const idIdx = headers.indexOf('id');
    const dateIdx = headers.indexOf('date');
    const debitsIdx = headers.indexOf('debits');
    const memoIdx = headers.indexOf('memo');

    for (let i = 1; i < data.length; i++) {
      const row = data[i];
      const dateVal = row[dateIdx];
      if (!dateVal) continue;
      
      // 날짜 포맷팅 (객체일 경우와 문자열일 경우 분기)
      let dateStr = "";
      if (dateVal instanceof Date) {
        dateStr = Utilities.formatDate(dateVal, ss.getSpreadsheetTimeZone(), "yyyy-MM-dd");
      } else {
        dateStr = String(dateVal);
      }

      // targetMonth (예: "2026-03") 로 시작하는 거래만 추출
      if (dateStr.startsWith(targetMonth)) {
        const debitsStr = row[debitsIdx];
        if (debitsStr) {
          try {
            const debits = JSON.parse(debitsStr);
            // 차변(debits) 중 비용 계정에 해당하는 것만 실제 지출로 인식
            debits.forEach((d, idx) => {
              if (expenseAccounts.includes(d.account)) {
                monthlyExpenses.push({
                  id: row[idIdx] + '-' + idx,
                  account: d.account,
                  date: dateStr,
                  memo: row[memoIdx] || '',
                  amount: Number(d.amount) || 0
                });
              }
            });
          } catch (e) { console.error("Transactions JSON parsing error", e); }
        }
      }
    }
  }

  // 3. Budgets 시트에서 해당 월의 예산 데이터 가져오기 (시트가 없으면 생성)
  let budgetsSheet = ss.getSheetByName('Budgets');
  let budgets = [];
  if (!budgetsSheet) {
    budgetsSheet = ss.insertSheet('Budgets');
    budgetsSheet.appendRow(['month', 'id', 'account', 'memo', 'amount']);
    budgetsSheet.setFrozenRows(1);
  } else {
    const data = budgetsSheet.getDataRange().getValues();
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === targetMonth) {
        budgets.push({
          id: data[i][1],
          account: data[i][2],
          memo: data[i][3],
          amount: Number(data[i][4]) || 0
        });
      }
    }
  }

  return {
    expenseAccounts: expenseAccounts,
    monthlyExpenses: monthlyExpenses,
    budgets: budgets
  };
}

/**
 * 작성한 예산 내역을 구글 시트(Budgets)에 안전하게 저장합니다.
 */
function saveBudgets(targetMonth, budgets) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName('Budgets');
  
  // 시트가 혹시 지워졌다면 재생성
  if (!sheet) {
    sheet = ss.insertSheet('Budgets');
    sheet.appendRow(['month', 'id', 'account', 'memo', 'amount']);
    sheet.setFrozenRows(1);
  }

  const data = sheet.getDataRange().getValues();
  const newData = [data[0]]; // 헤더 보존

  // 1. 저장할 타겟 월이 아닌 '다른 월'의 기존 데이터는 그대로 보존
  for (let i = 1; i < data.length; i++) {
    if (data[i][0] !== targetMonth) {
      newData.push(data[i]);
    }
  }

  // 2. 클라이언트에서 넘어온 타겟 월의 '새로운 예산 데이터' 추가
  if (budgets && budgets.length > 0) {
    budgets.forEach(b => {
      newData.push([targetMonth, b.id || Date.now(), b.account, b.memo, b.amount]);
    });
  }

  // 3. 시트 클리어 후 한 번에 데이터 덮어쓰기 (속도 및 정합성 보장)
  sheet.clear();
  sheet.getRange(1, 1, newData.length, newData[0].length).setValues(newData);
  sheet.setFrozenRows(1);

  return "Success";
}
